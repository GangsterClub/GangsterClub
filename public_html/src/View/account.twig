{% extends "tmpl/base.twig" %}
{% import "macro/alerts.twig" as alerts %}

{% block md %}
    <title>{{ __('account.page-title') }}</title>
{% endblock %}

{% block content %}
    <section class="max-w-5xl mx-auto min-h-screen py-16 px-6 text-gray-700 dark:text-gray-200">
        <div class="panel mb-6 flex items-center justify-between gap-4 p-3">
            <div>
                <h1 class="text-3xl font-bold">{{ __('account.headline') }}</h1>
            </div>
            <a class="inline-flex shrink-0 items-center gap-2 rounded border border-gray-400 bg-gray-100 px-4 py-2 text-sm font-semibold text-gray-700 shadow-sm hover:bg-gray-200 dark:border-gray-600 dark:bg-slate-800 dark:text-gray-200 dark:hover:bg-slate-700" href="{{ docRoot }}logout" aria-label="{{ __('account.logout') }}">
                <svg class="h-5 w-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v8" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7.05 6.35a8 8 0 1 0 9.9 0" />
                </svg>
                <span>{{ __('account.logout') }}</span>
            </a>
        </div>

        <div class="space-y-4 mb-6">
            {% for error in account.errors %}
                {{ alerts.error(error) }}
            {% endfor %}
            {% for success in account.success %}
                {{ alerts.success(success) }}
            {% endfor %}
        </div>

        <div class="grid gap-8 md:grid-cols-2">
            <div class="panel">
                <h2 class="text-xl font-semibold mb-4">{{ __('account.change-username-title') }}</h2>
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">{{ __('account.current-username', { 'username': user.username }) }}</p>
                <form method="POST" autocomplete="off" class="space-y-4">
                    <div>
                        <label for="username" class="block text-sm font-medium">{{ __('account.new-username-label') }}</label>
                        <input type="text" name="username" id="username" value="{{ user.username }}" minlength="3" maxlength="32" pattern="[A-Za-z0-9._-]+"
                            class="field-input"
                            required />
                        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">{{ __('account.username-helper') }}</p>
                    </div>
                    <button type="submit" name="submit_username" value="1"
                        class="btn-primary">
                        {{ __('account.save-username') }}
                    </button>
                </form>
            </div>

            <div class="panel">
                <h2 class="text-xl font-semibold mb-4">{{ __('account.change-email-title') }}</h2>
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">{{ __('account.current-email', { 'email': user.email }) }}</p>
                <form method="POST" autocomplete="off" class="space-y-4">
                    <div>
                        <label for="new_email" class="block text-sm font-medium">{{ __('account.new-email-label') }}</label>
                        <input type="email" name="new_email" id="new_email" value="" class="field-input" required />
                    </div>
                    <button type="submit" name="submit_email" value="1"
                        class="btn-primary">
                        {{ __('account.save-email') }}
                    </button>
                </form>
                {% if pendingEmailChange %}
                    <p class="text-xs text-amber-500 mt-4">{{ __('account.email-change-pending', {
                        'email': pendingEmailChange.newEmail,
                        'time': pendingEmailChange.expiresAt ? pendingEmailChange.expiresAt|date('H:i') : '?' }) }}</p>
                {% endif %}
            </div>
        </div>

        <div class="panel mt-8">
            <div class="flex justify-between items-start flex-col gap-2 md:flex-row md:items-center">
                <div>
                    <h2 class="text-xl font-semibold">{{ __('account.mfa-title') }}</h2>
                    <p class="text-sm text-gray-500 dark:text-gray-400">{{ __('account.mfa-instructions', { 'digits': mfa.digits, 'period': mfa.period }) }}</p>
                    <p class="text-sm text-gray-500 dark:text-gray-400">
                        {{ mfa.enabled ? __('account.mfa-description-enabled') : __('account.mfa-description-disabled', { 'digits': mfa.digits, 'period': mfa.period }) }}
                    </p>
                </div>
                <span class="text-sm font-semibold">
                    {{ mfa.enabled ? __('account.mfa-status-enabled') : __('account.mfa-status-disabled') }}
                </span>
            </div>

            <div class="mt-4 space-y-4">
                {% if not mfa.enabled %}
                    <form method="POST">
                        <button type="submit" name="submit_mfa_setup" value="1"
                            class="btn-secondary">
                            {{ __('account.mfa-start') }}
                        </button>
                    </form>
                {% else %}
                    <p class="text-sm text-gray-500 dark:text-gray-400">{{ __('account.mfa-setup-blocked-while-enabled') }}</p>
                {% endif %}

                {% if mfa.pendingSecret %}
                    <div class="border border-dashed border-gray-400 dark:border-gray-600 rounded p-4 space-y-3">
                        {% if mfa.qrCodeUrl %}
                            <div>
                                <img src="{{ mfa.qrCodeUrl }}" alt="TOTP QR code" class="w-48 h-48 rounded bg-white p-2" />
                            </div>
                        {% endif %}
                        <p class="text-sm">{{ __('account.mfa-secret-label') }}:<br><code class="text-lg font-mono">{{ mfa.pendingSecret }}</code></p>
                        {% if mfa.otpauth %}
                            <p class="text-sm break-all">{{ __('account.mfa-otpauth-label') }}:<br><code class="font-mono">{{ mfa.otpauth|raw }}</code></p>
                        {% endif %}
                        <form method="POST" class="grid gap-4 md:grid-cols-2">
                            <div>
                                <label for="mfa_code" class="block text-sm font-medium">{{ __('account.mfa-code-label') }}</label>
                                <input type="text" name="mfa_code" id="mfa_code" inputmode="numeric" pattern="\d*" maxlength="{{ mfa.digits }}"
                                    class="field-input"
                                    autocomplete="off" />
                                <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">{{ __('account.mfa-code-help') }}</p>
                            </div>
                            <div>
                                <label for="mfa_email_code" class="block text-sm font-medium">{{ __('account.mfa-email-code-label') }}</label>
                                <input type="text" name="mfa_email_code" id="mfa_email_code" inputmode="numeric" pattern="\d*" maxlength="{{ mfa.emailDigits }}"
                                    class="field-input"
                                    autocomplete="one-time-code" />
                                <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">{{ __('account.mfa-email-code-help', { 'digits': mfa.emailDigits, 'period': mfa.emailPeriod, 'email': user.email }) }}</p>
                            </div>
                            <div class="md:col-span-2 flex flex-wrap items-end gap-2">
                                <button type="submit" name="submit_mfa_confirm" value="1"
                                    class="btn-primary flex-1">
                                    {{ __('account.mfa-verify') }}
                                </button>
                                <button type="submit" name="submit_mfa_setup" value="1"
                                    class="btn-secondary">
                                    {{ __('account.mfa-email-code-resend') }}
                                </button>
                                <button type="submit" name="submit_mfa_cancel" value="1"
                                    class="btn-secondary">
                                    {{ __('account.mfa-cancel') }}
                                </button>
                            </div>
                        </form>
                    </div>
                {% endif %}

                {% if mfa.enabled %}
                    <div class="rounded-lg border border-red-200 dark:border-red-900/60 bg-red-50/80 dark:bg-red-950/30 p-4 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                        <div>
                            <p class="font-semibold text-red-700 dark:text-red-300">{{ __('account.mfa-disable-title') }}</p>
                            <p class="text-sm text-red-700/80 dark:text-red-200/80">{{ __('account.mfa-disable-help', { 'digits': mfa.digits }) }}</p>
                            <p class="text-xs text-red-700/70 dark:text-red-200/70 mt-2">{{ __('account.mfa-disable-recovery-note') }}</p>
                        </div>
                        <button type="button"
                            class="inline-flex justify-center items-center px-4 py-2 rounded border border-red-500 text-red-600 font-semibold"
                            onclick="document.getElementById('mfa-disable-modal').showModal()">
                            {{ __('account.mfa-disable') }}
                        </button>
                    </div>

                    <dialog id="mfa-disable-modal" class="modal-dialog backdrop:bg-black/60">
                        <div class="modal-panel">
                            <div class="flex items-start justify-between gap-4 mb-4">
                                <div>
                                    <h3 class="text-gray-700 dark:text-gray-200 text-lg font-semibold">{{ __('account.mfa-disable-modal-title') }}</h3>
                                    <p class="text-sm mt-1">{{ __('account.mfa-disable-modal-body', { 'digits': mfa.digits }) }}</p>
                                </div>
                                <form method="dialog">
                                    <button type="submit" class="text-gray-700 dark:text-gray-200 text-sm font-semibold underline">{{ __('account.mfa-modal-close') }}</button>
                                </form>
                            </div>

                            <form method="POST" class="space-y-4">
                                <div>
                                    <label for="mfa_disable_code" class="block text-sm font-medium">{{ __('account.mfa-disable-code-label') }}</label>
                                    <input type="text" name="mfa_disable_code" id="mfa_disable_code" inputmode="numeric" pattern="\d*" maxlength="{{ mfa.digits }}"
                                        class="field-input focus:ring-red-500"
                                        autocomplete="one-time-code" required />
                                    <p class="text-xs mt-1">{{ __('account.mfa-disable-code-help') }}</p>
                                </div>

                                <div class="flex flex-col-reverse gap-2 sm:flex-row sm:justify-end">
                                    <button type="button" onclick="document.getElementById('mfa-disable-modal').close()" class="btn-secondary w-full text-gray-700 dark:text-gray-200 sm:w-auto">
                                        {{ __('account.mfa-cancel') }}
                                    </button>
                                    <button type="submit" name="submit_mfa_disable" value="1"
                                        class="inline-flex justify-center items-center px-4 py-2 rounded bg-red-600 text-white font-semibold w-full sm:w-auto">
                                        {{ __('account.mfa-disable-confirm') }}
                                    </button>
                                </div>
                            </form>
                        </div>
                    </dialog>
                {% endif %}
            </div>
        </div>
    </section>
{% endblock %}
