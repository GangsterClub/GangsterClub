{
    "name": "gangsterclub/gc-online",
    "type": "project",
    "description": "GangsterClub is a free text based online role playing game. Can you manage becoming the best gangster?",
    "keywords": [
        "php",
        "mysql",
        "twig"
    ],
    "homepage": "https://gcov1.gangsterclub.nl",
    "license": "MIT",
    "authors": [
        {
            "name": "Michael Carrein",
            "email": "michael.carrein@hotmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-sodium": "*",
        "phpmailer/phpmailer": "^7.1.1",
        "spomky-labs/otphp": "^11.5.0",
        "symfony/yaml": "^7.0",
        "twig/twig": "^3.28.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "symfony/yaml": "PHP's yaml_parse_file() fallback package"
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml --testsuite unit --colors=never",
        "test:integration": "phpunit --configuration phpunit.xml --testsuite integration --colors=never",
        "analyse": "phpstan analyse src app tests --level=5 --memory-limit=512M",
        "lint": "php-cs-fixer fix --dry-run --diff --using-cache=no --config=.php-cs-fixer.php .",
        "security": "composer audit --locked",
        "check": "composer validate --no-check-publish && composer lint && composer analyse && composer test && composer security"
    },
    "autoload": {
        "psr-4": {
            "app\\": "app/",
            "src\\": "src/"
        }
    }
}
