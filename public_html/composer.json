{
    "name": "gangsterclub/gc-online",
    "type": "project",
    "description": "GangsterClub is a free text based online role playing game. Can you manage becoming the best gangster?",
    "keywords": [
        "php",
        "mysql",
        "twig"
    ],
    "homepage": "https://gcov1.gangsterclub.nl",
    "license": "proprietary",
    "authors": [
        {
            "name": "Michael Carrein",
            "email": "michael.carrein@hotmail.com"
        }
    ],
    "require": {
        "firebase/php-jwt": "^7.1",
        "phpmailer/phpmailer": "^7.1.1",
        "spomky-labs/otphp": "^11.5.0",
        "twig/twig": "^3.28.0"
    },
    "suggest": {
        "symfony/yaml": "PHP's yaml_parse_file() fallback package"
    },
    "autoload": {
        "psr-4": {
            "app\\": "app/",
            "src\\": "src/"
        }
    },
    "scripts": {
        "test": [
            "php tests/AccountRedirectStatusTest.php",
            "php tests/AuthEntryControllerTest.php",
            "php tests/AuthEntryServiceTest.php",
            "php tests/CsrfMiddlewareTest.php",
            "php tests/QueryBuilderSqlGenerationTest.php"
        ],
        "check": [
            "@test"
        ]
    }
}
